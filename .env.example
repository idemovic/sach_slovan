# Vzor konfiguracie pre kontaktny formular. Skopirujte ako `.env` a vyplnte.
#
# Jeden subor sluzi dvom veciam naraz:
#   - Vite pri builde precita len premenne s prefixom VITE_ (tie sa zapecu do
#     JS bundlu, preto tam patri IBA verejny kluc)
#   - public/php/contactForm.php precita sekcie nizsie cez parse_ini_file()
# Premenne bez prefixu VITE_ sa do buildu NEDOSTANU - SMTP heslo teda neunikne.
#
# NASADENIE: contactForm.php cita `.env` cez __DIR__/../../.env, teda O UROVEN
# VYSSIE ako korenovy adresar webu (dist/). Subor NIKDY nedavajte do dist/ -
# Apache by ho poslal ako obycajny text aj s heslom.

# --- frontend (verejny kluc widgetu Cloudflare Turnstile) ---
VITE_TURNSTILE_SITE_KEY=

# --- backend (contactForm.php) ---
[cloudflare_turnstile]
secret_key = ""

[smtp_settings]
host = ""
user = ""
pass = ""
port = 587

[email_settings]
from_address = ""
to_address = "info@slovan-bratislava.com"
