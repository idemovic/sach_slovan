; Konfiguracia kontaktneho formulara - cita ju public/php/contactForm.php.
; Skopiruj ako `.env.slovan` a vypln hodnoty.
;
; POZOR - toto je INI subor pre PHP parse_ini_file(), nie dotenv:
;   - komentare musia zacinat bodkociarkou (;). PHP uz znak # ako komentar
;     neberie, riadok by sa parsoval ako data.
;   - hodnoty davaj do uvodzoviek. Neuzavrete znaky ako ( ) { } | & ! ? ~
;     sposobia chybu parsovania a skript potom vrati "config_missing".
;
; UMIESTNENIE: subor patri MIMO korenovy adresar webu - skript ho hlada
; o uroven vyssie nad webrootom (viz README). Nikdy ho nekopiruj do dist/.

[cloudflare_turnstile]
secret_key = ""

[smtp_settings]
host = ""
user = ""
pass = ""
port = 587

[email_settings]
from_address = ""
to_address = "info@slovan-bratislava.com"
